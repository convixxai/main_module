            "description": "List of chat sessions",
            "content": {
              "application/json": {
                "example": [
                  {
                    "session_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
                    "created_at": "2026-02-23T10:00:00.000Z",
                    "updated_at": "2026-02-23T10:05:30.000Z",
                    "message_count": 6
                  }
                ]
              }

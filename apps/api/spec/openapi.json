        "description": "Returns decrypted messages for a session in chronological order.\nRequires x-api-key. Session must belong to customer.",
        "security": [{ "ApiKey": [] }],
        "parameters": [
          { "name": "session_id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
